# ─────────────────────────────────────────
# IRONBID Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────

# ── DATABASE (Supabase / Neon PostgreSQL) ──
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── SUPABASE ──
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# ── REDIS (Upstash) ──
REDIS_URL=rediss://default:[PASSWORD]@[HOST].upstash.io:6380
UPSTASH_REDIS_REST_URL=https://[HOST].upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── ABLY (WebSocket) ──
ABLY_API_KEY=your-app.key:secret
NEXT_PUBLIC_ABLY_CLIENT_KEY=your-app.key

# ── AUTH (Clerk) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# ── STRIPE ──
STRIPE_SECRET_KEY=sk_live_sk_live_51SI9fcBlZSVqeeWCbbpPDyvQxvEOak1hW2cs9bXoKdjO55inXESKH4rvNHJWXkfGAfJgpqkB1gdtz0scWspX9Lib00DKj6HqvS
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_ENDPOINT_ID=we_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_CARRIER_PLATFORM_FEE_PCT=8

# ── SLACK ──
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_BIDS=#ironbid-bids
SLACK_CHANNEL_ALERTS=#ironbid-alerts
SLACK_CHANNEL_SALES=#ironbid-sales
SLACK_CHANNEL_HAUL=#ironbid-haul
SLACK_CHANNEL_ERRORS=#ironbid-errors

# ── MEDIA (Supabase Storage / Cloudinary) ──
CLOUDINARY_CLOUD_NAME=ironbid
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ── EMAIL (Resend) ──
RESEND_API_KEY=re_...
EMAIL_FROM=support@ironbid.com

# ── FMCSA (Carrier Verification) ──
FMCSA_API_KEY=your-fmcsa-webkey

# ── GOOGLE MAPS (Route Distance) ──
GOOGLE_MAPS_API_KEY=AIza...

# ── SECURITY ──
AUTOBID_ENCRYPTION_KEY=64-char-hex-key-here
NEXTAUTH_SECRET=32-char-random-string

# ── APP URL (used in links + server actions) ──
NEXT_PUBLIC_APP_URL=https://ironbid-auction.vercel.app

# ── CLAUDE SUPPORT AGENT ──
ANTHROPIC_API_KEY=sk-ant-...
SUPPORT_AGENT_MODEL=claude-3-5-sonnet-latest
